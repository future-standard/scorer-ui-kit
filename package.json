{
  "name": "scorer-ui-kit",
  "version": "3.0.0",
  "description": "This project is a ui library with an example project of use cases and storybook to showcase the components",
  "main": "index.js",
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "sweep": "node scripts/sweep-stories.mjs",
    "start": "concurrently -n ui-lib,example -c blue,green \"npm run start:ui-lib\" \"npm run start:example\"",
    "start:all": "concurrently -n ui-lib,types,example,storybook -c blue,magenta,green,yellow \"npm run start:ui-lib\" \"npm run start:types\" \"npm run start:example\" \"npm run start:storybook\"",
    "start:ui-lib": "npm start --workspace=packages/ui-lib",
    "start:types": "npm run start:types --workspace=packages/ui-lib",
    "start:example": "npm start --workspace=packages/example",
    "start:storybook": "npm start --workspace=packages/storybook",
    "predeploy": "cd packages/example && npm run build && cd ../storybook && npm run build-storybook",
    "deploy": "gh-pages -d packages/example/build",
    "actions-deploy": "gh-pages -d packages/example/build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/future-standard/scorer-ui-kit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/future-standard/scorer-ui-kit/issues"
  },
  "homepage": "https://github.com/future-standard/scorer-ui-kit#readme",
  "workspaces": [
    "packages/storybook",
    "packages/example",
    "packages/ui-lib"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "concurrently": "10.0.3",
    "gh-pages": "6.3.0",
    "jsdom": "29.1.1",
    "playwright": "1.61.0",
    "vite": "8.0.16"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
