{
  "name": "scorer-ui-kit",
  "version": "3.0.0-beta.7",
  "description": "This project is a ui library with an example project of use cases and storybook to showcase the components",
  "main": "index.js",
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "predeploy": "cd packages/example && npm run build && cd ../storybook && npm run build-storybook",
    "deploy": "gh-pages -d packages/example/build",
    "actions-deploy": "gh-pages -d packages/example/build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/future-standard/scorer-ui-kit.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/future-standard/scorer-ui-kit/issues"
  },
  "homepage": "https://github.com/future-standard/scorer-ui-kit#readme",
  "workspaces": [
    "packages/storybook",
    "packages/example",
    "packages/ui-lib"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "gh-pages": "^6.3.0",
    "jsdom": "^26.1.0",
    "vite": "^8.0.5"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
