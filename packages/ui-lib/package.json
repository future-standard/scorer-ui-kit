{
  "name": "scorer-ui-kit",
  "version": "3.0.0-beta.7",
  "description": "SCORER UI Components",
  "author": "Josh Lipps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/future-standard/scorer-ui-kit.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.modern.js",
      "require": "./dist/index.js"
    },
    "./dist/Tables": {
      "types": "./dist/Tables/index.d.ts"
    },
    "./dist/LineUI": {
      "types": "./dist/LineUI/index.d.ts"
    },
    "./dist/LineUI/LineReducer": {
      "types": "./dist/LineUI/LineReducer.d.ts"
    },
    "./dist/Global": {
      "types": "./dist/Global/index.d.ts"
    },
    "./dist/Form": {
      "types": "./dist/Form/index.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": false,
  "engines": {
    "node": "18.x || 20.x || 22.x || 24.x"
  },
  "scripts": {
    "build": "vite build",
    "start": "vite build --watch",
    "prepublishOnly": "run-s build",
    "test": "run-s test:unit test:lint test:build",
    "test:build": "run-s build",
    "test:types": "tsc --noEmit",
    "test:lint": "eslint 'src/**/*.{ts,tsx}'",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "svgr": "svgr --typescript -d src/svg/ src/svg",
    "predeploy": "cd ../example && npm run build && cd ../storybook && npm run build-storybook",
    "deploy": "gh-pages -d ../example/build",
    "actions-deploy": "gh-pages -d ../example/build",
    "link": "npm link && npm link react && npm link react-dom && npm link react-router-dom && npm link styled-components"
  },
  "peerDependencies": {
    "react": "^17.0.2 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.2 || ^18.0.0 || ^19.0.0",
    "react-router": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "styled-components": "^6.1.0"
  },
  "devDependencies": {
    "@svgr/cli": "^6.3.1",
    "@types/lodash.debounce": "^4.0.7",
    "@types/lodash.isequal": "^4.5.6",
    "@types/node": "^20.19.35",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11",
    "vite": "^8.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@future-standard/icons": "^3.0.0",
    "date-fns": "^4.1.0",
    "immutability-helper": "^3.1.1",
    "lodash.debounce": "^4.0.7",
    "lodash.isequal": "^4.5.0"
  },
  "directories": {
    "example": "example"
  },
  "bugs": {
    "url": "https://github.com/future-standard/scorer-ui-kit/issues"
  },
  "homepage": "https://future-standard.github.io/scorer-ui-kit/#/"
}
